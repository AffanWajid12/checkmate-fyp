generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model users {
  id                   String                  @id @db.Uuid
  email                String                  @unique
  name                 String
  role                 Role                    @default(STUDENT)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @default(now()) @updatedAt
  profile_picture      String?
  comments             announcement_comments[] @relation("UserComments")
  ownedCourses         courses[]               @relation("TeacherCourses")
  enrolledCourses      enrollments[]           @relation("StudentEnrollments")
  generatedAssessments generated_assessments[] @relation("TeacherGeneratedAssessments")
  referenceMaterials   reference_materials[]   @relation("TeacherReferenceMaterials")
  submissions          submissions[]           @relation("UserSubmissions")
  evaluations          evaluations[]           @relation("UserEvaluations")

  @@map("users")
  @@schema("public")
}

model enrollments {
  id         String       @id @default(uuid()) @db.Uuid
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @default(now()) @updatedAt
  course_id  String       @db.Uuid
  student_id String       @db.Uuid
  attendance attendance[] @relation("EnrollmentAttendance")
  course     courses      @relation("CourseEnrollments", fields: [course_id], references: [id], onDelete: Cascade)
  student    users        @relation("StudentEnrollments", fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([course_id, student_id])
  @@map("enrollments")
  @@schema("public")
}

model courses {
  id                  String                @id @default(uuid()) @db.Uuid
  title               String
  description         String?
  code                String                @unique
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @default(now()) @updatedAt
  teacher_id          String                @db.Uuid
  announcements       announcements[]       @relation("CourseAnnouncements")
  attendance_sessions attendance_sessions[] @relation("CourseAttendanceSessions")
  teacher             users                 @relation("TeacherCourses", fields: [teacher_id], references: [id], onDelete: Cascade)
  students            enrollments[]         @relation("CourseEnrollments")

  @@map("courses")
  @@schema("public")
}

model announcements {
  id          String                   @id @default(uuid()) @db.Uuid
  title       String
  description String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @default(now()) @updatedAt
  course_id   String                   @db.Uuid
  comments    announcement_comments[]  @relation("AnnouncementComments")
  resources   announcement_resources[] @relation("AnnouncementResources")
  course      courses                  @relation("CourseAnnouncements", fields: [course_id], references: [id], onDelete: Cascade)
  assessments assessments[]            @relation("AnnouncementAssessments")

  @@map("announcements")
  @@schema("public")
}

model announcement_resources {
  id              String        @id @default(uuid()) @db.Uuid
  bucket_path     String
  file_name       String
  file_size       Int
  mime_type       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  announcement_id String        @db.Uuid
  announcement    announcements @relation("AnnouncementResources", fields: [announcement_id], references: [id], onDelete: Cascade)

  @@map("announcement_resources")
  @@schema("public")
}

model source_materials {
  id            String      @id @default(uuid()) @db.Uuid
  bucket_path   String
  file_name     String
  file_size     Int
  mime_type     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  assessment_id String      @db.Uuid
  assessment    assessments @relation("AssessmentSourceMaterials", fields: [assessment_id], references: [id], onDelete: Cascade)

  @@map("source_materials")
  @@schema("public")
}

model announcement_comments {
  id              String        @id @default(uuid()) @db.Uuid
  content         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  announcement_id String        @db.Uuid
  user_id         String        @db.Uuid
  announcement    announcements @relation("AnnouncementComments", fields: [announcement_id], references: [id], onDelete: Cascade)
  user            users         @relation("UserComments", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("announcement_comments")
  @@schema("public")
}

model assessments {
  id               String             @id @default(uuid()) @db.Uuid
  title            String
  instructions     String?
  type             AssessmentType     @default(QUIZ)
  total_marks      Float?
  blueprint        Json?
  due_date         DateTime?
  visible_to_students Boolean         @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  announcement_id  String             @db.Uuid
  announcement     announcements      @relation("AnnouncementAssessments", fields: [announcement_id], references: [id], onDelete: Cascade)
  source_materials source_materials[] @relation("AssessmentSourceMaterials")
  submissions      submissions[]      @relation("AssessmentSubmissions")
  grading_blueprint grading_blueprints? @relation("AssessmentBlueprint")

  @@map("assessments")
  @@schema("public")
}

model submissions {
  id            String           @id @default(uuid()) @db.Uuid
  status          SubmissionStatus @default(SUBMITTED)
  submitted_at    DateTime         @default(now())
  grade           Float?
  feedback        String?
  createdAt       DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt
  user_id       String           @db.Uuid
  assessment_id String           @db.Uuid
  attachments   attachments[]    @relation("SubmissionAttachments")
  assessment    assessments      @relation("AssessmentSubmissions", fields: [assessment_id], references: [id], onDelete: Cascade)
  user          users            @relation("UserSubmissions", fields: [user_id], references: [id], onDelete: Cascade)
  evaluation    evaluations?     @relation("SubmissionEvaluation")

  @@unique([user_id, assessment_id])
  @@map("submissions")
  @@schema("public")
}

model attachments {
  id            String      @id @default(uuid()) @db.Uuid
  bucket_path   String
  file_name     String
  file_size     Int
  mime_type     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  submission_id String      @db.Uuid
  submission    submissions @relation("SubmissionAttachments", fields: [submission_id], references: [id], onDelete: Cascade)

  @@map("attachments")
  @@schema("public")
}

model attendance_sessions {
  id        String       @id @default(uuid()) @db.Uuid
  title     String?
  date      DateTime     @db.Date
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now()) @updatedAt
  course_id String       @db.Uuid
  records   attendance[] @relation("SessionAttendance")
  course    courses      @relation("CourseAttendanceSessions", fields: [course_id], references: [id], onDelete: Cascade)

  @@map("attendance_sessions")
  @@schema("public")
}

model attendance {
  id            String              @id @default(uuid()) @db.Uuid
  status        AttendanceStatus    @default(ABSENT)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt
  enrollment_id String              @db.Uuid
  session_id    String              @db.Uuid
  enrollment    enrollments         @relation("EnrollmentAttendance", fields: [enrollment_id], references: [id], onDelete: Cascade)
  session       attendance_sessions @relation("SessionAttendance", fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([enrollment_id, session_id])
  @@map("attendance")
  @@schema("public")
}

model generated_assessments {
  id                  String                                     @id @default(uuid()) @db.Uuid
  title               String?
  subject             String
  assessment_type     AssessmentType                             @default(QUIZ)
  difficulty          String
  instructions        String?
  question_count      Int?
  question_payload    Json
  status              String?
  createdAt           DateTime                                   @default(now())
  updatedAt           DateTime                                   @default(now()) @updatedAt
  teacher_id          String                                     @db.Uuid
  reference_materials generated_assessment_reference_materials[] @relation("GeneratedAssessmentReferences")
  teacher             users                                      @relation("TeacherGeneratedAssessments", fields: [teacher_id], references: [id], onDelete: Cascade)

  @@map("generated_assessments")
  @@schema("public")
}

model reference_materials {
  id                    String                                     @id @default(uuid()) @db.Uuid
  bucket_path           String
  file_name             String
  file_size             Int
  mime_type             String
  createdAt             DateTime                                   @default(now())
  updatedAt             DateTime                                   @default(now()) @updatedAt
  teacher_id            String                                     @db.Uuid
  generated_assessments generated_assessment_reference_materials[] @relation("ReferenceMaterialGeneratedAssessments")
  teacher               users                                      @relation("TeacherReferenceMaterials", fields: [teacher_id], references: [id], onDelete: Cascade)

  @@map("reference_materials")
  @@schema("public")
}

model generated_assessment_reference_materials {
  id                      String                @id @default(uuid()) @db.Uuid
  generated_assessment_id String                @db.Uuid
  reference_material_id   String                @db.Uuid
  generated_assessment    generated_assessments @relation("GeneratedAssessmentReferences", fields: [generated_assessment_id], references: [id], onDelete: Cascade)
  reference_material      reference_materials   @relation("ReferenceMaterialGeneratedAssessments", fields: [reference_material_id], references: [id], onDelete: Cascade)

  @@unique([generated_assessment_id, reference_material_id])
  @@map("generated_assessment_reference_materials")
  @@schema("public")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN

  @@schema("public")
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
  EXAM

  @@schema("public")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE

  @@schema("public")
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  GRADED

  @@schema("public")
}

model grading_blueprints {
  id            String      @id @default(uuid()) @db.Uuid
  assessment_id String      @unique @db.Uuid
  total_marks   Float
  structure     Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  assessment    assessments @relation("AssessmentBlueprint", fields: [assessment_id], references: [id], onDelete: Cascade)

  @@map("grading_blueprints")
  @@schema("public")
}

model evaluations {
  id               String      @id @default(uuid()) @db.Uuid
  submission_id    String      @unique @db.Uuid
  total_score      Float
  overall_feedback String?
  details          Json
  evaluated_by     String      @db.Uuid
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  submission       submissions @relation("SubmissionEvaluation", fields: [submission_id], references: [id], onDelete: Cascade)
  evaluator        users       @relation("UserEvaluations", fields: [evaluated_by], references: [id], onDelete: Cascade)

  @@map("evaluations")
  @@schema("public")
}
